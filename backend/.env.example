# Mongo connection string
MONGODB_URI=mongodb://127.0.0.1:27017/innovchain

# JWT signing secret (use a long random string in real deployments)
JWT_SECRET=change-me-innovchain-dev-secret

# HTTP port for the Express API
PORT=4000

# CORS origin allowed to call this API (Vite dev server default)
CORS_ORIGIN=http://localhost:5173

# Blockchain: 'local' talks to a Hardhat node started with `npm run node` in ../contracts
# (npx hardhat node), 'testnet' points RPC_URL/OPERATOR_PRIVATE_KEY at a public testnet
# such as Sepolia. See docs/API.md "Blockchain service interface".
CHAIN_MODE=local

RPC_URL=http://127.0.0.1:8545

# Well-known Hardhat dev account #0 private key. Pre-funded on any local Hardhat node.
# This is a PUBLIC, well-known test key (same on every Hardhat install) - never use it,
# or this pattern, outside of local development.
OPERATOR_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# Address of the deployed OwnershipRegistry contract. If unset, the backend falls back to
# reading contracts/deployments/<network>.json (network = "localhost" when CHAIN_MODE=local,
# else CHAIN_MODE) relative to the repo root.
OWNERSHIP_REGISTRY_ADDRESS=

# Address of the deployed LicenseNFT contract. Same fallback behavior as
# OWNERSHIP_REGISTRY_ADDRESS above (reads contracts/deployments/<network>.json's "licenseNft"
# field if unset).
LICENSE_NFT_ADDRESS=

# Fixed platform demo address that receives the university's 5% share of every sale
# (PoC simplification - a single demo "university" wallet, not a real per-university
# account system). Defaults to Hardhat dev account #1 if unset.
UNIVERSITY_WALLET_ADDRESS=0x70997970C51812dc3A010C7d01b50e0d17dc79C8

# InnovChain's own platform wallet, receiving a fixed 10% of every sale. Defaults to Hardhat
# dev account #2 if unset.
PLATFORM_WALLET_ADDRESS=0x3C44CdDdB6a900fa2b585dd299e03d12FA4293BC

# Local disk directory (relative to backend/) where uploaded project files are stored.
UPLOAD_DIR=uploads
